; Godot Engine project configuration file
;
; Lumo 3D - Mobile 3D Lumo App Shell
;
; LEITLINIE: Nutze moderne Mobile-3D-Techniken: Godot Mobile Renderer,
; Quality Profiles, GLB/glTF Asset Pipeline, KTX2/BasisU Texturkompression,
; PBR Materials, Mobile Shader Fallbacks, Touch Raycasting, Safe-Area UI,
; GPU Instancing/MultiMesh, LOD/Culling, baked lighting, Headless CI und
; Android Export Diagnostics. Ziel ist keine Tech-Demo, sondern eine
; performante 3D-Lernwelt auf Android.

config_version=5

[application]

config/name="Lumo 3D"
config/description="Mobile 3D Lumo-Lernwelt fuer Kinder. Boot -> Intro
-> Home -> Portale (Lernen/Spiele/Eltern). Forward+ Desktop / Mobile
Android / GL_Compatibility Web."
run/main_scene="res://scenes/app/boot.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://scripts/systems/event_bus.gd"
PerformanceManager="*res://scripts/systems/performance_manager.gd"
MobileRuntime="*res://scripts/app/mobile_runtime.gd"
SceneRouter="*res://scripts/app/scene_router.gd"
AssetLoader="*res://scripts/systems/asset_loader.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"

[rendering]

renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="mobile"
renderer/rendering_method.web="gl_compatibility"
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/screen_space_aa=1
environment/defaults/default_clear_color=Color(0.08, 0.06, 0.12, 1)
environment/defaults/default_environment="res://scenes/default_env.tres"
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
